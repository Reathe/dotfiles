{{- $BWS_ACCESS_TOKEN := env "BWS_ACCESS_TOKEN" -}}
{{- if not $BWS_ACCESS_TOKEN -}}
{{-   $BWS_ACCESS_TOKEN = promptStringOnce . "BWS_ACCESS_TOKEN" "Write your BWS_ACCESS_TOKEN" -}}
{{- end -}}
scriptEnv:
  INSTALL_PACKAGES: "true"
  # BitwardenSecrets
  BWS_REINSTALL: "false"
  BWS_SHOW_INSTALLER: "false"
  BWS_ACCESS_TOKEN: {{ $BWS_ACCESS_TOKEN | quote }}

data:
  FORCE_RUN_ONCHANGE: "false"
  INSTALL_EXTRAS: "false"
  BWS_ACCESS_TOKEN: {{ $BWS_ACCESS_TOKEN | quote }}

{{ if eq .chezmoi.os "windows" -}}
hooks:
  read-source-state:
    pre:
      command: "powershell"
      args:
        [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "{{ .chezmoi.sourceDir }}/.install-pw-manager.ps1",
        ]

interpreters:
  nu:
    command: "C:/Program Files/nu/bin/nu.exe"

{{ else if and (eq .chezmoi.os "linux") (ne .chezmoi.osRelease.name "NixOS") -}}
hooks:
  read-source-state:
    pre:
      command: "sh"
      args:
        [
          "{{ .chezmoi.sourceDir }}/.install-pw-manager.sh"
        ]
{{ end -}}
